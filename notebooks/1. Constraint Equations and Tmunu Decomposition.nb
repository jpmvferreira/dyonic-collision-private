Cell[BoxData[{
 RowBox[{
  RowBox[{"Format", "[", "z0", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(z\), \(0\)]\)\>\""}], "\n", 
 RowBox[{
