Cell[TextData[{
 "Computing ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["S", "-"], "ij"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2fef3bf1-c5aa-42dc-8695-16b49d9dc46b"],
 " is a little bit tricker, but we\[CloseCurlyQuote]re gonna do it anyways.\n\
The first term of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["S", "-"], "ij"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6f1f9a32-c662-46d2-b868-23f3b0508a5d"],
 " is just ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["\[Gamma]", "-"], "ij"], 
    OverscriptBox["\[CurlyEpsilon]", "-"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "708df01e-f302-4ba2-85d0-2758cc1856da"],
 ", and we already know how to transform that.\nBut the second term, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["N", "ij"], "=", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", 
       RowBox[{"4", "\[Pi]"}]]}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SubscriptBox[
         OverscriptBox["E", "-"], "i"], 
        SubscriptBox[
         OverscriptBox["E", "-"], "j"]}], "+", 
       RowBox[{
        SubscriptBox[
         OverscriptBox["B", "-"], "i"], 
        SubscriptBox[
         OverscriptBox["B", "-"], "j"]}]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "494f4fce-8843-4b8a-b9d5-5f9d01b1347d"],
 ", we don\[CloseCurlyQuote]t, so let\[CloseCurlyQuote]s handle that one \
(warning: takes a while to compute)."
}], "Text",
 CellChangeTimes->{{3.9830047876168423`*^9, 3.983004833930438*^9}, {
   3.983004987466007*^9, 3.983005144922982*^9}, {3.983005201425858*^9, 
