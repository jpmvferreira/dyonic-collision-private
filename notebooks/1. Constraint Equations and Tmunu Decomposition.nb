Cell[BoxData[
 RowBox[{
  RowBox[{"Si", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"Pp", " ", "Qm"}], "-", 
      RowBox[{"Pm", " ", "Qp"}]}], 
