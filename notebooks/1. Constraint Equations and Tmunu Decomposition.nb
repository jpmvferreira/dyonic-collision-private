Cell[CellGroupData[{

Cell["2. Equations", "Section",
 CellChangeTimes->{{3.982730673425374*^9, 
  3.982730675805632*^9}},ExpressionUUID->"bece05fa-fa5f-4e97-827c-\
221661afa8cb"],

Cell[TextData[{
 "Based on [Bozzola2019], the GR constraints after the CTT decomposition and \
suitable definitions are:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Del]", "2"], "\[Psi]"}], "+", 
     RowBox[{
      FractionBox["1", "8"], 
      SuperscriptBox["\[Psi]", 
       RowBox[{"-", "7"}]], 
      SubscriptBox[
       OverscriptBox["A", "-"], "ij"], 
      SuperscriptBox[
       OverscriptBox["A", "-"], "ij"]}], "+", 
     RowBox[{"2", "\[Pi]", " ", 
      SuperscriptBox["\[Psi]", 
       RowBox[{"-", "3"}]], 
      OverscriptBox["\[CurlyEpsilon]", "-"]}]}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"7b218eca-22d3-4c0c-bd2d-dd8b27b5d870"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Del]", "2"], 
      SuperscriptBox["V", "i"]}], "+", 
     RowBox[{
      FractionBox["1", "3"], 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["D", "-"], "i"], "(", 
       RowBox[{
        SubscriptBox[
         OverscriptBox["D", "-"], "j"], 
        SuperscriptBox["V", "j"]}], ")"}]}], "-", 
     RowBox[{"8", "\[Pi]", " ", 
      SuperscriptBox[
       OverscriptBox["S", "-"], "i"]}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"d91ebaea-0bd9-4ffa-94af-bf3f5e71e579"],
 "\n\nwhere the bar denotes quantities in flat spacetime and the source terms \
are given by [Bozzola2019,Alcubierre2009]\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[CurlyEpsilon]", "-"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"8", "\[Pi]"}]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         OverscriptBox["E", "-"], "i"], 
        SubscriptBox[
         OverscriptBox["E", "-"], "i"]}], "+", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["B", "-"], "i"], 
        SubscriptBox[
         OverscriptBox["B", "-"], "i"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"9e717a5e-1ea7-48c1-a389-f2ebb9761653"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["S", "-"], "i"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"4", "\[Pi]"}]], 
     SubscriptBox[
      OverscriptBox["\[Epsilon]", "-"], "ijk"], 
     SuperscriptBox[
      OverscriptBox["E", "-"], "j"], 
     SuperscriptBox[
      OverscriptBox["B", "-"], "k"]}]}], TraditionalForm]],ExpressionUUID->
  "0590de3e-7b01-4b7a-97fa-398c56de35bc"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["S", "-"], "ij"], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"8", "\[Pi]"}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox[
          OverscriptBox["\[Gamma]", "-"], "ij"], "(", 
         RowBox[{
          RowBox[{
           SuperscriptBox[
            OverscriptBox["E", "-"], "i"], 
           SubscriptBox[
            OverscriptBox["E", "-"], "i"]}], "+", 
          RowBox[{
           SuperscriptBox[
            OverscriptBox["B", "-"], "i"], 
           SubscriptBox[
            OverscriptBox["B", "-"], "i"]}]}], ")"}], "-", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SubscriptBox[
             OverscriptBox["E", "-"], "i"], 
            SubscriptBox[
             OverscriptBox["E", "-"], "j"]}], "+", 
           RowBox[{
            SubscriptBox[
             OverscriptBox["B", "-"], "i"], 
            SubscriptBox[
             OverscriptBox["B", "-"], "j"]}]}], ")"}]}]}], ")"}]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        OverscriptBox["\[Gamma]", "-"], "ij"], 
       OverscriptBox["\[CurlyEpsilon]", "-"]}], "-", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"4", "\[Pi]"}]], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SubscriptBox[
           OverscriptBox["E", "-"], "i"], 
          SubscriptBox[
           OverscriptBox["E", "-"], "j"]}], "+", 
         RowBox[{
          SubscriptBox[
           OverscriptBox["B", "-"], "i"], 
          SubscriptBox[
           OverscriptBox["B", "-"], "j"]}]}], ")"}]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9506bfd9-2af4-4de4-b80e-ebaae3108f44"],
 "\n\t\nwhere the re-scaled quantities are related with the physical \
quantities as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "ij"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "4"], 
     SubscriptBox[
      OverscriptBox["\[Gamma]", "-"], "ij"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "99f4e5f0-9435-483a-b502-e1415011f94c"],
 "\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CurlyEpsilon]", "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", 
      RowBox[{"-", "8"}]], 
     OverscriptBox["\[CurlyEpsilon]", "-"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9be33d88-cd2a-465f-b013-e8caa05c5870"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", 
      RowBox[{"-", "6"}]], 
     SubscriptBox[
      OverscriptBox["S", "-"], "i"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "69c051ad-95f4-423a-8411-edc82b9e0f5d"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "ij"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", 
      RowBox[{"-", "4"}]], 
     SubscriptBox[
      OverscriptBox["S", "-"], "ij"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "26f9ebff-b22c-490a-b73b-757282f42564"],
 "\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["E", "-"], "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "6"], 
     SuperscriptBox["E", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "ac2418fc-3e2c-49f1-b9c4-329127da7bf7"],
 "          ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["E", "-"], "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "2"], 
     SubscriptBox["E", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "2d964b20-be46-42e8-ab59-99be0c6afb35"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["B", "-"], "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "6"], 
     SuperscriptBox["B", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "3b5436cf-f396-4a88-8f10-4d6282346214"],
 "          ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["B", "-"], "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "2"], 
     SubscriptBox["B", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "cb632178-fc4b-44f8-9600-5f116f56bc36"],
 "\n\t\nThere are also the Maxwell constraints\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["D", "-"], "i"], 
     SuperscriptBox[
      OverscriptBox["E", "-"], "i"]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"3f8818b8-f854-44e4-a24b-70e4cb0865e1"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["D", "-"], "i"], 
     SuperscriptBox[
      OverscriptBox["B", "-"], "i"]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"e622c057-b9e9-49f0-b8d0-98b609ca8aee"]
}], "Text",
 CellChangeTimes->{{3.9827300300743093`*^9, 3.9827301855753517`*^9}, {
  3.9827302184816427`*^9, 3.982730598192172*^9}, {3.9827343972535467`*^9, 
  3.982734398204494*^9}, {3.9830023814743137`*^9, 3.9830025435660963`*^9}, {
  3.98300273556105*^9, 3.983002796057576*^9}, {3.983002920219046*^9, 
  3.9830029644893827`*^9}, {3.9830030277942533`*^9, 3.9830031747760468`*^9}, {
  3.983006774468232*^9, 
  3.983006811479576*^9}},ExpressionUUID->"27168695-6d28-417d-99bd-\
f2efebcdce5f"],

Cell[TextData[{
 "\nAssuming two black holes located along the z-axis at a distance ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["z", "0"], TraditionalForm]],ExpressionUUID->
  "21d013c7-ee92-4c0b-baed-b247168aadb3"],
 " from the origin, the conformal electromagnetic field reads\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["E", "-"], "i"], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       SubscriptBox["Q", "-"], 
       RowBox[{"||", 
        SubscriptBox[
         OverscriptBox["r", "\[RightVector]"], "-"], 
        SuperscriptBox["||", "3"]}]], 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "-"]}], "+", 
     RowBox[{
      FractionBox[
       SubscriptBox["Q", "+"], 
       RowBox[{"||", 
        SubscriptBox[
         OverscriptBox["r", "\[RightVector]"], "+"], 
        SuperscriptBox["||", "3"]}]], 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "+"]}]}]}], TraditionalForm]],
  ExpressionUUID->"3b82ea0b-246d-4e73-baac-2e373a326a58"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["B", "-"], "i"], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       SubscriptBox["P", "-"], 
       RowBox[{"||", 
        SubscriptBox[
         OverscriptBox["r", "\[RightVector]"], "-"], 
        SuperscriptBox["||", "3"]}]], 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "-"]}], "+", 
     RowBox[{
      FractionBox[
       SubscriptBox["P", "+"], 
       RowBox[{"||", 
        SubscriptBox[
         OverscriptBox["r", "\[RightVector]"], "+"], 
        SuperscriptBox["||", "3"]}]], 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "+"]}]}]}], TraditionalForm]],
  ExpressionUUID->"601774e4-2e58-49e5-a829-baa327aa9882"],
 "\n\t\nwhere\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["r", "\[RightVector]"], "-"], "=", 
    RowBox[{"(", 
     RowBox[{"x", ",", "y", ",", 
      RowBox[{"z", "-", 
       SubscriptBox["z", "0"]}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6c9dd5fb-2e68-4a42-8958-11355b4adddf"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["r", "\[RightVector]"], "+"], "=", 
    RowBox[{"(", 
     RowBox[{"x", ",", "y", ",", 
      RowBox[{"z", "+", 
       SubscriptBox["z", "0"]}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "877a211e-7edd-4859-b9c5-c8b4bd11b48b"],
 "\n\nUnder these assumptions, the source terms are\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[CurlyEpsilon]", "-"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"8", "\[Pi]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         SubsuperscriptBox["Q", "-", "2"], " ", "+", " ", 
         SubsuperscriptBox["P", "-", "2"]}], 
        RowBox[{"||", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "-"], 
         SuperscriptBox["||", "4"]}]], "+", 
       FractionBox[
        RowBox[{
         SubsuperscriptBox["Q", "+", "2"], " ", "+", " ", 
         SubsuperscriptBox["P", "+", "2"]}], 
        RowBox[{"||", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "+"], 
         SuperscriptBox["||", "4"]}]], "+", 
       RowBox[{"2", " ", 
        FractionBox[
         RowBox[{
          RowBox[{
           SubscriptBox["P", "-"], 
           SubscriptBox["P", "+"]}], "+", 
          RowBox[{
           SubscriptBox["Q", "-"], 
           SubscriptBox["Q", "+"]}]}], 
         RowBox[{"||", 
          SubscriptBox[
           OverscriptBox["r", "\[RightVector]"], "-"], 
          SuperscriptBox["||", "3"], 
          RowBox[{"||", 
           SubscriptBox[
            OverscriptBox["r", "\[RightVector]"], "+"], 
           SuperscriptBox["||", "3"]}]}]], 
        RowBox[{
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "-"], "\[CenterDot]", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "+"]}]}]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"0d71e5d0-a97c-4e33-8af3-b547ca3fe256"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["S", "-"], "i"], "=", 
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{
        SubscriptBox["P", "+"], 
        SubscriptBox["Q", "-"]}], "-", 
       RowBox[{
        SubscriptBox["P", "-"], 
        SubscriptBox["Q", "+"]}]}], 
      RowBox[{"2", "\[Pi]"}]], 
     FractionBox[
      SubscriptBox["z", "0"], 
      RowBox[{"||", 
       SubscriptBox[
        OverscriptBox["r", "\[RightVector]"], "-"], 
       SuperscriptBox["||", "3"], "||", 
       SubscriptBox[
        OverscriptBox["r", "\[RightVector]"], "+"], 
       SuperscriptBox["||", "3"]}]], 
     RowBox[{"(", 
      RowBox[{"y", ",", 
       RowBox[{"-", "x"}], ",", "0"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"1f31896c-5d6a-4f4e-9e75-8905c98e847a"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["S", "-"], "ij"], "=", " ", "..."}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4c184744-dd4e-40cd-a34a-06b0e683a02a"],
 "  (too long to write)"
}], "Text",
 CellChangeTimes->{
  3.982730761194792*^9, {3.982730833572348*^9, 3.982730848197901*^9}, {
   3.982730969157813*^9, 3.9827310454952183`*^9}, {3.98273111171506*^9, 
   3.9827311483194637`*^9}, {3.982731299231382*^9, 3.982731358424068*^9}, {
   3.9827329660705633`*^9, 3.982732976942896*^9}, {3.982733011737111*^9, 
   3.982733033927243*^9}, {3.9827330685962963`*^9, 3.982733404416298*^9}, {
   3.9827337956700172`*^9, 3.982733858277046*^9}, {3.983003193155604*^9, 
   3.983003208179983*^9}, {3.98300674521019*^9, 3.983006764054983*^9}, {
   3.9830068301550207`*^9, 3.983006834264841*^9}, {3.983252952157339*^9, 
   3.9832529556737022`*^9}, {3.9832532744521914`*^9, 
   3.983253280767192*^9}},ExpressionUUID->"3273fdfe-571a-407b-b55c-\
41836b2b5f7f"],

Cell[TextData[{
 "\nUsing the following definitions, inspired by the duality transformation\n\
\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Q", "-"], "=", 
    RowBox[{
     SubscriptBox["T", "-"], 
     RowBox[{"cos", "(", 
      SubscriptBox["\[Alpha]", "-"], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "98fb486a-5004-472c-ae5e-162d5b48cb38"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "-"], "=", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["T", "-"]}], 
     RowBox[{"sin", "(", 
      SubscriptBox["\[Alpha]", "-"], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "947193d8-1d3a-4809-aca2-9af9394115aa"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Q", "+"], "=", 
    RowBox[{
     SubscriptBox["T", "+"], 
     RowBox[{"cos", "(", 
      SubscriptBox["\[Alpha]", "+"], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cc56c568-c0fc-45bf-aa5b-a7413394cceb"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "+"], "=", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["T", "+"]}], 
     RowBox[{"sin", "(", 
      SubscriptBox["\[Alpha]", "+"], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "58c07073-82c6-4a15-8664-eb42d944ca7b"],
 "\n\nwhere \n\t- ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", 
    RowBox[{"+", 
     RowBox[{"/", "-"}]}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "571df881-a50f-46f4-88b1-e9b151a00906"],
 " is the angle of the rotation for each of the BH\[CloseCurlyQuote]s\n\t- ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<=", 
    SubscriptBox["T", 
     RowBox[{"+", 
      RowBox[{"/", "-"}]}]], "<=", 
    SubscriptBox["M", 
     RowBox[{"+", 
      RowBox[{"/", "-"}]}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "23430d9f-0f02-4192-a356-6cf4e6991f86"],
 " the (total) charge of each BH\n\nthe source terms become\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[CurlyEpsilon]", "-"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"8", "\[Pi]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         SubsuperscriptBox["T", "-", "2"], " "}], 
        RowBox[{"||", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "-"], 
         SuperscriptBox["||", "4"]}]], "+", 
       FractionBox[
        SubsuperscriptBox["T", "+", "2"], 
        RowBox[{"||", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "+"], 
         SuperscriptBox["||", "4"]}]], "+", 
       RowBox[{"2", " ", 
        FractionBox[
         RowBox[{
          SubscriptBox["T", "-"], 
          SubscriptBox["T", "+"], 
          RowBox[{"Cos", "[", "\[CapitalDelta]\[Alpha]", "]"}]}], 
         RowBox[{"||", 
          SubscriptBox[
           OverscriptBox["r", "\[RightVector]"], "-"], 
          SuperscriptBox["||", "3"], 
          RowBox[{"||", 
           SubscriptBox[
            OverscriptBox["r", "\[RightVector]"], "+"], 
           SuperscriptBox["||", "3"]}]}]], 
        RowBox[{
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "-"], "\[CenterDot]", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "+"]}]}]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"08fff8a6-05b1-403d-948e-7035de52bea5"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["S", "-"], "i"], "=", 
    RowBox[{
     FractionBox[
      RowBox[{
       SubscriptBox["T", "+"], 
       SubscriptBox["T", "-"], 
       RowBox[{"Sin", "[", "\[CapitalDelta]\[Alpha]", "]"}]}], 
      RowBox[{"2", "\[Pi]"}]], 
     FractionBox[
      SubscriptBox["z", "0"], 
      RowBox[{"||", 
       SubscriptBox[
        OverscriptBox["r", "\[RightVector]"], "-"], 
       SuperscriptBox["||", "3"], "||", 
       SubscriptBox[
        OverscriptBox["r", "\[RightVector]"], "+"], 
       SuperscriptBox["||", "3"]}]], 
     RowBox[{"(", 
      RowBox[{"y", ",", 
       RowBox[{"-", "x"}], ",", "0"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"7841d61b-2184-45c5-b5ac-395b026fc481"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["S", "-"], "ij"], "=", " ", "..."}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1570ac39-17b5-4861-ae91-af81cdacac63"],
 "  (too long to write, only depends on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"cos", "(", "\[CapitalDelta]\[Alpha]", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f2927bde-516b-4a88-8868-fff04096b0f2"],
 ")\n\nwhere\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]\[Alpha]", "=", 
    RowBox[{
     SubscriptBox["\[Alpha]", "-"], "-", 
     SubscriptBox["\[Alpha]", "+"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "279763dc-8372-45af-ae2a-14ccef5ae1b0"],
 "\t\n\nTherefore, solutions with the same ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    RowBox[{
     SubscriptBox["M", "-"], ",", 
     SubscriptBox["M", "+"], ",", 
     SubscriptBox["T", "-"], ",", 
     SubscriptBox["T", "+"], ",", "\[CapitalDelta]\[Alpha]"}], " ", "}"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "15fffcbf-7d0e-41c0-b1cf-d496191a91c0"],
 " are dual to each other, regardless of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    RowBox[{
     SubscriptBox["\[Alpha]", "-"], ",", 
     SubscriptBox["a", "+"]}], " ", "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "641056ab-82ed-4c38-8edf-66d6e08911ff"],
 ".\n\nI have a fancy graph on my notebooks that shows how to give an \
interpretation to this ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]\[Alpha]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f7d534a8-ab92-4e01-bfd6-06f52877c79a"],
 ". \nShame I can\[CloseCurlyQuote]t put it here, but it says that:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]\[Alpha]", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c37d351f-c7b1-4ae1-9dee-d215cc70ff6d"],
 "            is dual to      Q vs  Q\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]\[Alpha]", "=", 
    RowBox[{"\[Pi]", "/"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "50c84a7b-2d33-4f6f-8790-14cd5939ea1d"],
 "2       is dual to      Q vs -P\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]\[Alpha]", "=", "\[Pi]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a797470d-e2be-4d38-9238-6c91a1432897"],
 "           is dual to      Q vs -Q\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]\[Alpha]", "=", 
    RowBox[{"3", 
     RowBox[{"\[Pi]", "/", "2"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e8b01743-ca07-4c79-99ff-f475f70e706a"],
 "   is dual to      Q vs   P"
}], "Text",
 CellChangeTimes->CompressedData["
