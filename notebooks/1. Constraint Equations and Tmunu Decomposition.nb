Cell[BoxData[{
 RowBox[{
  RowBox[{"rm", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", 
     RowBox[{"z", "-", "z0"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rp", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", 
     RowBox[{"z", "+", "z0"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Ei", "=", 
   RowBox[{
    RowBox[{
     FractionBox["Qm", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "-", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "-", "z0"}]}], "}"}]}], "+", 
    RowBox[{
     FractionBox["Qp", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "+", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "+", "z0"}]}], "}"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Bi", "=", 
   RowBox[{
    RowBox[{
     FractionBox["Pm", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "-", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "-", "z0"}]}], "}"}]}], "+", 
    RowBox[{
     FractionBox["Pp", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "+", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "+", "z0"}]}], "}"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98273129394736*^9, 3.982731294811899*^9}, {
