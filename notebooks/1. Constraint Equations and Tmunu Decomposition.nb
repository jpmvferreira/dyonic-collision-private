  ":=", "\"\<\!\(\*SubscriptBox[\(T\), \(-\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "Tp", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(T\), \(+\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "\[Alpha]m", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(-\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "\[Alpha]p", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(+\)]\)\>\""}], "\n", 
 RowBox[{
