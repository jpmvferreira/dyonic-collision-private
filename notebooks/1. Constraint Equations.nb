Cell[CellGroupData[{

Cell["2. Equations", "Section",
 CellChangeTimes->{{3.982730673425374*^9, 
  3.982730675805632*^9}},ExpressionUUID->"bece05fa-fa5f-4e97-827c-\
221661afa8cb"],

Cell[TextData[{
 "Based on [Bozzola2019], the GR constraints after the CTT decomposition and \
suitable definitions are:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Del]", "2"], "\[Psi]"}], "+", 
     RowBox[{
      FractionBox["1", "8"], 
      SuperscriptBox["\[Psi]", 
       RowBox[{"-", "7"}]], 
      SubscriptBox[
       OverscriptBox["A", "-"], "ij"], 
      SuperscriptBox[
       OverscriptBox["A", "-"], "ij"]}], "+", 
     RowBox[{"2", "\[Pi]", " ", 
      SuperscriptBox["\[Psi]", 
       RowBox[{"-", "3"}]], 
      OverscriptBox["\[CurlyEpsilon]", "-"]}]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7b218eca-22d3-4c0c-bd2d-dd8b27b5d870"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Del]", "2"], 
      SuperscriptBox["V", "i"]}], "+", 
     RowBox[{
      FractionBox["1", "3"], 
      RowBox[{
       SuperscriptBox[
        OverscriptBox["D", "-"], "i"], "(", 
       RowBox[{
        SubscriptBox[
         OverscriptBox["D", "-"], "j"], 
        SuperscriptBox["V", "j"]}], ")"}]}], "-", 
     RowBox[{"8", "\[Pi]", " ", 
      SuperscriptBox[
       OverscriptBox["S", "-"], "i"]}]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d91ebaea-0bd9-4ffa-94af-bf3f5e71e579"],
 "\n\nwhere the bar denotes quantities in flat spacetime and the source terms \
are given by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[CurlyEpsilon]", "-"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"8", "\[Pi]"}]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         OverscriptBox["E", "-"], "i"], 
        SubscriptBox[
         OverscriptBox["E", "-"], "i"]}], "+", 
       RowBox[{
        SuperscriptBox[
         OverscriptBox["B", "-"], "i"], 
        SubscriptBox[
         OverscriptBox["B", "-"], "i"]}]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9e717a5e-1ea7-48c1-a389-f2ebb9761653"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["S", "-"], "i"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"4", "\[Pi]"}]], 
     SuperscriptBox[
      OverscriptBox["\[Epsilon]", "-"], "ijk"], 
     SubscriptBox[
      OverscriptBox["E", "-"], "j"], 
     SubscriptBox[
      OverscriptBox["B", "-"], "k"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0590de3e-7b01-4b7a-97fa-398c56de35bc"],
 "\n\t\nand the re-scaled fields are related with the physical fields as\n\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["E", "-"], "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "6"], 
     SuperscriptBox["E", "i"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ac2418fc-3e2c-49f1-b9c4-329127da7bf7"],
 "          ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["E", "-"], "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "2"], 
     SubscriptBox["E", "i"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2d964b20-be46-42e8-ab59-99be0c6afb35"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["B", "-"], "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "6"], 
     SuperscriptBox["B", "i"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3b5436cf-f396-4a88-8f10-4d6282346214"],
 "          ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["B", "-"], "i"], "=", 
    RowBox[{
     SuperscriptBox["\[Psi]", "2"], 
     SubscriptBox["B", "i"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cb632178-fc4b-44f8-9600-5f116f56bc36"],
 "\n\t\nThere are also the Maxwell constraints\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["D", "-"], "i"], 
     SuperscriptBox[
      OverscriptBox["E", "-"], "i"]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3f8818b8-f854-44e4-a24b-70e4cb0865e1"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["D", "-"], "i"], 
     SuperscriptBox[
      OverscriptBox["B", "-"], "i"]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"e622c057-b9e9-49f0-b8d0-98b609ca8aee"]
}], "Text",
 CellChangeTimes->{{3.9827300300743093`*^9, 3.9827301855753517`*^9}, {
  3.9827302184816427`*^9, 3.982730598192172*^9}, {3.9827343972535467`*^9, 
  3.982734398204494*^9}},ExpressionUUID->"27168695-6d28-417d-99bd-\
f2efebcdce5f"],

Cell[TextData[{
 "\nAssuming two black holes located along the z-axis at a distance ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["z", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "21d013c7-ee92-4c0b-baed-b247168aadb3"],
 " from the origin, the conformal electromagnetic field reads\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["E", "-"], "i"], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       SubscriptBox["Q", "-"], 
       RowBox[{"||", 
        SubscriptBox[
         OverscriptBox["r", "\[RightVector]"], "-"], 
        SuperscriptBox["||", "3"]}]], 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "-"]}], "+", 
     RowBox[{
      FractionBox[
       SubscriptBox["Q", "+"], 
       RowBox[{"||", 
        SubscriptBox[
         OverscriptBox["r", "\[RightVector]"], "+"], 
        SuperscriptBox["||", "3"]}]], 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "+"]}]}]}], TraditionalForm]],
  ExpressionUUID->"3b82ea0b-246d-4e73-baac-2e373a326a58"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["B", "-"], "i"], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       SubscriptBox["P", "-"], 
       RowBox[{"||", 
        SubscriptBox[
         OverscriptBox["r", "\[RightVector]"], "-"], 
        SuperscriptBox["||", "3"]}]], 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "-"]}], "+", 
     RowBox[{
      FractionBox[
       SubscriptBox["P", "+"], 
       RowBox[{"||", 
        SubscriptBox[
         OverscriptBox["r", "\[RightVector]"], "+"], 
        SuperscriptBox["||", "3"]}]], 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "+"]}]}]}], TraditionalForm]],
  ExpressionUUID->"601774e4-2e58-49e5-a829-baa327aa9882"],
 "\n\t\nwhere\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["r", "\[RightVector]"], "-"], "=", 
    RowBox[{"(", 
     RowBox[{"x", ",", "y", ",", 
      RowBox[{"z", "-", 
       SubscriptBox["z", "0"]}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6c9dd5fb-2e68-4a42-8958-11355b4adddf"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["r", "\[RightVector]"], "+"], "=", 
    RowBox[{"(", 
     RowBox[{"x", ",", "y", ",", 
      RowBox[{"z", "+", 
       SubscriptBox["z", "0"]}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "877a211e-7edd-4859-b9c5-c8b4bd11b48b"],
 "\n\nUnder these assumptions, the source terms are\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[CurlyEpsilon]", "-"], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"8", "\[Pi]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         SubsuperscriptBox["Q", "-", "2"], " ", "+", " ", 
         SubsuperscriptBox["P", "-", "2"]}], 
        RowBox[{"||", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "-"], 
         SuperscriptBox["||", "4"]}]], "+", 
       FractionBox[
        RowBox[{
         SubsuperscriptBox["Q", "+", "2"], " ", "+", " ", 
         SubsuperscriptBox["P", "+", "2"]}], 
        RowBox[{"||", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "+"], 
         SuperscriptBox["||", "4"]}]], "+", 
       RowBox[{"2", " ", 
        FractionBox[
         RowBox[{
          RowBox[{
           SubscriptBox["P", "-"], 
           SubscriptBox["P", "+"]}], "+", 
          RowBox[{
           SubscriptBox["Q", "-"], 
           SubscriptBox["Q", "+"]}]}], 
         RowBox[{"||", 
          SubscriptBox[
           OverscriptBox["r", "\[RightVector]"], "-"], 
          SuperscriptBox["||", "3"], 
          RowBox[{"||", 
           SubscriptBox[
            OverscriptBox["r", "\[RightVector]"], "+"], 
           SuperscriptBox["||", "3"]}]}]], 
        RowBox[{
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "-"], "\[CenterDot]", 
         SubscriptBox[
          OverscriptBox["r", "\[RightVector]"], "+"]}]}]}], ")"}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0d71e5d0-a97c-4e33-8af3-b547ca3fe256"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["S", "-"], "i"], "=", 
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{
        SubscriptBox["P", "+"], 
        SubscriptBox["Q", "-"]}], "-", 
       RowBox[{
        SubscriptBox["P", "-"], 
        SubscriptBox["Q", "+"]}]}], 
      RowBox[{"2", "\[Pi]"}]], 
     FractionBox[
      SubscriptBox["z", "0"], 
      RowBox[{"||", 
       SubscriptBox[
        OverscriptBox["r", "\[RightVector]"], "-"], 
       SuperscriptBox["||", "3"], "||", 
       SubscriptBox[
        OverscriptBox["r", "\[RightVector]"], "+"], 
       SuperscriptBox["||", "3"]}]], 
     RowBox[{"(", 
      RowBox[{"y", ",", 
       RowBox[{"-", "x"}], ",", "0"}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1f31896c-5d6a-4f4e-9e75-8905c98e847a"]
}], "Text",
 CellChangeTimes->{
  3.982730761194792*^9, {3.982730833572348*^9, 3.982730848197901*^9}, {
   3.982730969157813*^9, 3.9827310454952183`*^9}, {3.98273111171506*^9, 
   3.9827311483194637`*^9}, {3.982731299231382*^9, 3.982731358424068*^9}, {
   3.9827329660705633`*^9, 3.982732976942896*^9}, {3.982733011737111*^9, 
   3.982733033927243*^9}, {3.9827330685962963`*^9, 3.982733404416298*^9}, {
   3.9827337956700172`*^9, 
   3.982733858277046*^9}},ExpressionUUID->"3273fdfe-571a-407b-b55c-\
41836b2b5f7f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Computations", "Section",
 CellChangeTimes->{{3.982731236753499*^9, 
  3.98273124020304*^9}},ExpressionUUID->"29d2201f-05e7-4f0d-90c2-\
c3af9e7b90dd"],

Cell["Prettify the output", "Text",
 CellChangeTimes->{{3.982731283769301*^9, 
  3.9827312869141493`*^9}},ExpressionUUID->"0f2faf27-b51c-4eee-af84-\
cf5c8f2eae36"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Format", "[", "z0", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(z\), \(0\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "Qm", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(Q\), \(-\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "Qp", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(Q\), \(+\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "Pm", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(P\), \(-\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "Pp", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(P\), \(+\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "Mm", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(M\), \(-\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "Mp", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(M\), \(+\)]\)\>\""}]}], "Input",
 CellChangeTimes->{{3.9810289136338177`*^9, 3.98102895547998*^9}, {
  3.982731413662016*^9, 3.982731454543913*^9}, {3.982734822657874*^9, 
  3.982734829055963*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"79e01f5f-ecdb-4cfa-8357-eb2eb0e2e06d"],

Cell["Define auxiliary quantities", "Text",
 CellChangeTimes->{{3.982731250996304*^9, 3.982731258748826*^9}, {
  3.982731292502344*^9, 
  3.982731293337728*^9}},ExpressionUUID->"7deb031b-1695-46ad-b63a-\
5fd30180365c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"rm", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", 
     RowBox[{"z", "-", "z0"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rp", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", 
     RowBox[{"z", "+", "z0"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Ei", "=", 
   RowBox[{
    RowBox[{
     FractionBox["Qm", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "-", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "-", "z0"}]}], "}"}]}], "+", 
    RowBox[{
     FractionBox["Qp", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "+", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "+", "z0"}]}], "}"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Bi", "=", 
   RowBox[{
    RowBox[{
     FractionBox["Pm", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "-", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "-", "z0"}]}], "}"}]}], "+", 
    RowBox[{
     FractionBox["Pp", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "+", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "+", "z0"}]}], "}"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98273129394736*^9, 3.982731294811899*^9}, {
  3.982731371661633*^9, 3.982731381965967*^9}, {3.982731474460994*^9, 
  3.982731513955497*^9}, {3.9827318099323483`*^9, 3.982731850359188*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"fee8cf65-ebf4-4a3d-b054-0df68b4a0a48"],

Cell["Check Maxwell constraints", "Text",
 CellChangeTimes->{{3.982731519631641*^9, 3.982731524871696*^9}, {
  3.9827335508240013`*^9, 
  3.98273355537901*^9}},ExpressionUUID->"3775386c-062a-48e0-bf1c-\
573cf0da16a2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["\[Del]", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]], ".", "Ei"}], "//", 
  "Simplify"}], "\n", 
 RowBox[{
  RowBox[{
   SubscriptBox["\[Del]", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]], ".", "Bi"}], "//", 
  "Simplify"}]}], "Input",
 CellChangeTimes->{{3.982731628179308*^9, 3.982731644174738*^9}, {
  3.982731882383662*^9, 3.98273188615627*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"2b620d4f-9960-4d87-8898-c883e82c5f28"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{{3.982731639271617*^9, 3.982731673147841*^9}, 
   3.982731851924341*^9, 3.98273188650813*^9},
 CellLabel->"Out[19]=",ExpressionUUID->"309f1017-4814-40a2-a0b0-693fccea6c94"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{{3.982731639271617*^9, 3.982731673147841*^9}, 
   3.982731851924341*^9, 3.982731886520644*^9},
 CellLabel->"Out[20]=",ExpressionUUID->"f19ff620-ac24-48ab-8848-f4e4bbf921f1"]
}, Open  ]],

Cell["Compute the source terms", "Text",
 CellChangeTimes->{{3.9827335575011797`*^9, 
  3.98273356047761*^9}},ExpressionUUID->"6e4a80d6-ec0e-4260-87a8-\
9a7175df8d0f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", 
    RowBox[{"8", "\[Pi]"}]], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Ei", ".", "Ei"}], "+", 
     RowBox[{"Bi", ".", "Bi"}]}], ")"}]}], "//", "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.982731533369524*^9, 3.982731560116091*^9}, 
   3.982731607391123*^9, {3.982731858548626*^9, 3.982731859037086*^9}, 
   3.9827318922706203`*^9, {3.9827321355574083`*^9, 3.982732136476774*^9}, 
   3.982732761289473*^9},
 CellLabel->"In[35]:=",ExpressionUUID->"df5b7036-d59b-4ddf-8bcc-2b10ebf378f1"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", 
   RowBox[{"8", " ", "\[Pi]"}]], 
  RowBox[{"(", 
   RowBox[{
    FractionBox[
     SuperscriptBox["\<\"\\!\\(\\*SubscriptBox[\\(P\\), \\(-\\)]\\)\"\>", 
      "2"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["x", "2"], "+", 
        SuperscriptBox["y", "2"], "+", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
          "z", "-", "\<\"\\!\\(\\*SubscriptBox[\\(z\\), \\(0\\)]\\)\"\>"}], 
          ")"}], "2"]}], ")"}], "2"]], "+", 
    FractionBox[
     SuperscriptBox["\<\"\\!\\(\\*SubscriptBox[\\(Q\\), \\(-\\)]\\)\"\>", 
      "2"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
