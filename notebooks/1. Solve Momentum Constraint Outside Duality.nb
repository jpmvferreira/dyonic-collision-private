Cell[CellGroupData[{

Cell["3. Solve Numerically", "Section",
 CellChangeTimes->{{3.9808519301573277`*^9, 
  3.980851935573106*^9}},ExpressionUUID->"37e5ef15-4e63-4c0e-80ff-\
14b91b12cc74"],

Cell["Specify physical and compactification parameters", "Text",
 CellChangeTimes->{{3.980588300049728*^9, 3.98058830330059*^9}, {
   3.981027455353147*^9, 3.9810274559596653`*^9}, {3.9810288907915993`*^9, 
   3.981028892671632*^9}, 
   3.981028971842211*^9},ExpressionUUID->"97312662-bf79-442f-81f9-\
d8f9ef9522d2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"z0", "->", "10"}], ",", "\[IndentingNewLine]", 
     RowBox[{"cP", "->", "100"}], ",", "\[IndentingNewLine]", 
     RowBox[{"cZ", "->", "100"}]}], "\[IndentingNewLine]", "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.980588305804947*^9, 3.980588309317851*^9}, {
   3.980855598678896*^9, 3.980855598711113*^9}, {3.980855840865362*^9, 
   3.9808558426016073`*^9}, {3.9808558954750767`*^9, 3.980855914749257*^9}, {
   3.9810288759959173`*^9, 3.981028908869385*^9}, {3.981103565315015*^9, 
   3.981103567013859*^9}, 3.981104597426784*^9, {3.981105328151051*^9, 
   3.981105328342229*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"b75f7f0e-2776-414e-8b17-d75a76294a78"],

Cell["Let\[CloseCurlyQuote]s create a grid to solve the PDE", "Text",
 CellChangeTimes->{{3.980851685829496*^9, 
  3.980851691741288*^9}},ExpressionUUID->"d8b1cbb8-29de-431f-a1d4-\
691133d9b066"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "number", " ", "of", " ", "points", " ", "in", " ", "each", " ", 
    "dimension"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"n", "=", "250"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"create", " ", "non"}], "-", 
     RowBox[{
     "uniform", " ", "spacing", " ", "using", " ", "a", " ", "power", " ", 
      "law", " ", "distribution"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"power", "=", "2"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"points", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"i", "/", 
          RowBox[{"(", 
           RowBox[{"n", "-", "1"}], ")"}]}], ")"}], "^", "power"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", 
         RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "create", " ", "2", "D", " ", "grid", " ", "with", " ", "same", " ", 
     "distribution", " ", "in", " ", "both", " ", "dimensions"}], " ", "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"coords", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"points", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
           RowBox[{"points", "[", 
            RowBox[{"[", 
             RowBox[{"j", "+", "1"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", 
           RowBox[{"n", "-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", 
           RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"create", " ", "quad", " ", "element", " ", "connectivity"}], " ",
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"incidents", "=", 
     RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"i", "+", 
            RowBox[{"j", "*", "n"}]}], ",", 
           RowBox[{"i", "+", "1", "+", 
            RowBox[{"j", "*", "n"}]}], ",", 
           RowBox[{"i", "+", "1", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "+", "1"}], ")"}], "*", "n"}]}], ",", 
           RowBox[{"i", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "+", "1"}], ")"}], "*", "n"}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", 
           RowBox[{"n", "-", "2"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", 
       "\[IndentingNewLine]", "1"}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"create", " ", "mesh"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"mesh", "=", 
     RowBox[{"ToElementMesh", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<Coordinates\>\"", "->", "coords"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<MeshElements\>\"", "->", 
        RowBox[{"{", 
         RowBox[{"QuadElement", "[", "incidents", "]"}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", "visualize", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"mesh", "[", "\"\<Wireframe\>\"", "]"}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9808516923849373`*^9, 3.9808516959042587`*^9}, {
  3.9808517290488873`*^9, 3.9808517857451773`*^9}, {3.9808519419719*^9, 
  3.9808519548069553`*^9}, {3.980852064758192*^9, 3.9808520657794523`*^9}, {
  3.980852199367947*^9, 3.980852199403193*^9}, {3.980852928388275*^9, 
