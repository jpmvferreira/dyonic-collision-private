Cell["Solve PDE using NDSolve with appropriate boundary conditions", "Text",
 CellChangeTimes->{{3.9805715275353317`*^9, 3.980571531723628*^9}, {
  3.9808519712277727`*^9, 
  3.980851976165639*^9}},ExpressionUUID->"5e064747-38e4-45c4-88e7-\
9118773bc4f7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"pde", "==", 
         RowBox[{
          RowBox[{"NeumannValue", "[", 
           RowBox[{"0", ",", 
            RowBox[{"P", "==", "0"}]}], "]"}], "+", 
          RowBox[{"NeumannValue", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Z", "==", "0"}]}], "]"}]}]}], "/.", "params"}], "//", 
       "Simplify"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"u", "[", 
          RowBox[{"0", ",", "Z"}], "]"}], "==", "0"}], ","}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"1", ",", "Z"}], "]"}], "==", "0"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"P", ",", "1"}], "]"}], "==", "0"}]}], "\[IndentingNewLine]", 
     "}"}], ",", "\[IndentingNewLine]", "u", ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"P", ",", "Z"}], "}"}], "\[Element]", "mesh"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.98050147544827*^9, 3.980501579814061*^9}, {
   3.980504185097823*^9, 3.98050418698914*^9}, {3.980504294537839*^9, 
