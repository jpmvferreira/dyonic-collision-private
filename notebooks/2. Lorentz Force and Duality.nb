27ae5be1a84d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"r1", "=", 
   RowBox[{"{", 
    RowBox[{"x1", ",", "y1", ",", "z1"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"r2", "=", 
    RowBox[{"{", 
     RowBox[{"x2", ",", "y2", ",", "z2"}], "}"}]}], ";"}], "\n"}], "\n", 
