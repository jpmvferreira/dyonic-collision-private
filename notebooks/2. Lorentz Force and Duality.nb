 RowBox[{
  RowBox[{"E1", "=", 
   RowBox[{"Q1", 
    FractionBox["r1", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"r1", ".", "r1"}], ")"}], 
      RowBox[{"3", "/", "2"}]]]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"E2", "=", 
    RowBox[{"Q2", 
     FractionBox["r2", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"r2", ".", "r2"}], ")"}], 
       RowBox[{"3", "/", "2"}]]]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"B1", "=", 
   RowBox[{"P1", 
    FractionBox["r1", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"r1", ".", "r1"}], ")"}], 
      RowBox[{"3", "/", "2"}]]]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"B2", "=", 
   RowBox[{"P2", 
    FractionBox["r2", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"r2", ".", "r2"}], ")"}], 
