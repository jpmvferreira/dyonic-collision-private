     OverscriptBox["v", "\[RightVector]"], "2"]}], TraditionalForm]],
  ExpressionUUID->"b6fb5998-8291-4c22-9fd8-f726d098d1c6"],
 " and electric/magnetic charges ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Q", "1"], ",", 
    SubscriptBox["Q", "2"], ",", 
    SubscriptBox["P", "1"], ",", 
