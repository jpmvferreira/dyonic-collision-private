  ":=", "\"\<\!\(\*SubscriptBox[\(T\), \(2\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", "\[Alpha]2", "]"}], 
   ":=", "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(2\)]\)\>\""}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "x1", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(x\), \(1\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "y1", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(y\), \(1\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", "z1", "]"}], 
   ":=", "\"\<\!\(\*SubscriptBox[\(z\), \(1\)]\)\>\""}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "x2", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(x\), \(2\)]\)\>\""}], "\n", 
 RowBox[{
