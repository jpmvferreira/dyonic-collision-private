Cell[TextData[{
 "Define two point particles located at ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["r", "\[RightVector]"], "1"], ",", 
    SubscriptBox[
     OverscriptBox["r", "\[RightVector]"], "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "69b88083-788f-48f4-a6a8-36c9dcb02e6f"],
 " with velocity ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["v", "\[RightVector]"], "1"], ",", 
