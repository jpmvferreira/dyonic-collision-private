   ":=", "\"\<\!\(\*SubscriptBox[\(z\), \(2\)]\)\>\""}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "vx1", "]"}], 
  ":=", "\"\<\!\(\*SubsuperscriptBox[\(v\), \(1\), \((x)\)]\)\>\""}], "\n", 
