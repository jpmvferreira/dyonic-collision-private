Cell[TextData[{
 "We see that the Lorentz Force only depends on ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]\[Alpha]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4c099ff7-bc5e-466e-bcf6-c8a8ad41fe73"],
 ", and not on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    RowBox[{
     SubscriptBox["\[Alpha]", "1"], ",", 
     SubscriptBox["\[Alpha]", "2"]}], " ", "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "19b2444b-f6f5-4628-8245-1712f38d040d"],
 " individually.\nTherefore, we can take ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "2"], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c77323b7-b413-42ce-9764-bdb4bb07b761"],
 ", corresponding to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "2"], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "88441969-7733-473c-950c-80dc80bdb499"],
 ", and consider just ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d2101800-c411-4137-909e-c57ac44614be"],
 " for simplicity."
}], "Text",
