Cell[BoxData[{
 RowBox[{
  RowBox[{"Format", "[", "Q1", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(Q\), \(1\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "P1", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(P\), \(1\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "T1", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(T\), \(1\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", "\[Alpha]1", "]"}], 
   ":=", "\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(1\)]\)\>\""}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "Q2", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(Q\), \(2\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "P2", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(P\), \(2\)]\)\>\""}], "\n", 
