Cell[TextData[{
 "Notes to self:\n\t- Not sure how choosing ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "1"], "=", 
    RowBox[{
     SubscriptBox["m", "2"], "=", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c67f0b72-bd75-4f00-9c58-cc33a64a3cd7"],
 " impacts the parameters ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    RowBox[{"a", ",", " ", "e", ",", " ", "\[Theta]"}], " ", "}"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5ed8c545-355d-469c-9c6a-e2c0ee9d3cd4"],
 ".\n\t- Don\[CloseCurlyQuote]t know what should be the limits of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    RowBox[{"a", ",", " ", "e", ",", " ", "\[Theta]"}], " ", "}"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c1f54a2b-3ff7-4a54-ac70-23527d4b9e42"],
 ", assuming that I want closed orbits."
}], "Text",
 CellChangeTimes->{{3.9835251179154387`*^9, 3.983525190168922*^9}, {
  3.983526821244378*^9, 
  3.983526822626425*^9}},ExpressionUUID->"2003623c-1ea4-4a5e-be50-\
725badec1363"],

Cell[TextData[{
 "Notes about the dynamics:\n\t- For \[OpenCurlyDoubleQuote]circular\
\[CloseCurlyDoubleQuote] orbits (i.e. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"e", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ebbcbbc1-747a-4715-b38e-97ccbfe0b56e"],
 "), since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"de", "/", "dt"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "361cb676-98c6-4e51-b16b-c69bd665bfbc"],
 ", they will remain circular until merger.\n\t- For \
\[OpenCurlyDoubleQuote]non-circular\[CloseCurlyDoubleQuote] orbits, ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a04c608d-a707-4d0f-ae61-5e7824f094f0"],
 " will decrease (making vertical variation smaller) and ",
 Cell[BoxData[
  FormBox["\[Theta]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dfb983a6-07e2-4a9e-b27d-bc93c5b800b4"],
 " will decrease (making the aperture of the cone smaller)."
}], "Text",
 CellChangeTimes->{{3.983526689668561*^9, 
  3.983526852782474*^9}},ExpressionUUID->"b0615717-f7c3-4b96-b749-\
4fcc085c725d"]
