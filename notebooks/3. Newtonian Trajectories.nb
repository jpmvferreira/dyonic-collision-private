   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{3.9827299211673117`*^9, 3.982729957746978*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"7c26ba81-35a8-4b25-a0f1-0c2687d15151"],

Cell[TextData[{
 "Following [Liu2020], define the relative position vector ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["R", "\[RightVector]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7db21dea-c423-44df-985a-3d51aa8f93be"]
}], "Text",
 CellChangeTimes->{{3.983521914261724*^9, 
  3.983521939238081*^9}},ExpressionUUID->"59bad06c-ae5c-43be-8af0-\
c86db1e2cb92"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", 
    RowBox[{"\[Phi]_", ",", "a_", ",", "e_", ",", "\[Theta]_"}], "]"}], ":=", 
   
   RowBox[{
    FractionBox[
     RowBox[{"a", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["e", "2"]}], ")"}]}], 
     RowBox[{"1", "+", 
      RowBox[{"e", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Phi]", " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "]"}]}]}]], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", "\[Theta]", "]"}], 
       RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
      RowBox[{
       RowBox[{"Sin", "[", "\[Theta]", "]"}], 
       RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.983521941203258*^9, 3.983521992048101*^9}, {
  3.983522811735387*^9, 3.983522814994232*^9}, {3.983523486949645*^9, 
  3.9835234909269533`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"f1e9130a-e5ea-4ce8-af04-9556dfb2ef5a"],

Cell[TextData[{
 "Where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    RowBox[{"a", ",", "e", ",", "\[Theta]"}], " ", "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ccf53bc7-657e-4ca5-99c3-4526a250d249"],
 " are parameters related to the physical characteristics of the system, and ",
 Cell[BoxData[
  FormBox["\[Phi]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3bb7faf5-fb27-4354-8447-15eb73ad4da5"],
 " is the angular position that is a function of time."
}], "Text",
 CellChangeTimes->{{3.983521996044281*^9, 
  3.983522069292695*^9}},ExpressionUUID->"e4e94580-4903-42ba-acef-\
433e47bebd4a"],

Cell[TextData[{
 "Assuming equal mass bodies where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "1"], "=", 
    RowBox[{
     SubscriptBox["m", "2"], "=", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c051a789-c038-4868-936f-12f22932ef45"],
 ", the position of each body wrt the C.M. of the system is"
}], "Text",
 CellChangeTimes->{{3.9835221187062883`*^9, 3.983522171791465*^9}, {
  3.9835229204647417`*^9, 3.9835229392740593`*^9}, {3.983525113748496*^9, 
  3.983525114039835*^9}},ExpressionUUID->"33948ef6-67d2-4a6f-a891-\
502d8cdabeaf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"r1", "[", 
    RowBox[{"\[Phi]_", ",", "a_", ",", "e_", ",", "\[Theta]_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "2"]}], 
    RowBox[{"R", "[", 
     RowBox[{"\[Phi]", ",", "a", ",", "e", ",", "\[Theta]"}], "]"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"r2", "[", 
    RowBox[{"\[Phi]_", ",", "a_", ",", "e_", ",", "\[Theta]_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"R", "[", 
     RowBox[{"\[Phi]", ",", "a", ",", "e", ",", "\[Theta]"}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.983522152084079*^9, 3.983522184000486*^9}, {
  3.98352281726125*^9, 3.9835228273859663`*^9}, {3.983523496014737*^9, 
  3.9835235179148912`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"69010e4c-35df-41b3-af42-7c4d3f30f9fb"],

