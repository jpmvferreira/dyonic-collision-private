Cell[CellGroupData[{

Cell["5. Check Uncompactified Solution", "Section",
 CellChangeTimes->{{3.981027308722088*^9, 
  3.98102732908039*^9}},ExpressionUUID->"5123e71e-b628-4250-bc57-\
b5641a6cf72d"],

Cell["The solution in un-compactified coordinates is", "Text",
 CellChangeTimes->{{3.9805729659192257`*^9, 3.980572972708444*^9}, {
  3.980849590595791*^9, 3.980849600000695*^9}, {3.980851997987648*^9, 
  3.980852000886286*^9}},ExpressionUUID->"675dff6d-bf67-464d-94b4-\
e21804993911"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"solv", "[", 
    RowBox[{"\[Rho]_", ",", "z_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"v", "[", 
     RowBox[{
      FractionBox["\[Rho]", 
       RowBox[{"cP", "+", "\[Rho]"}]], ",", 
      FractionBox["z", 
       RowBox[{"cZ", "+", "z"}]]}], "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.980507123415929*^9, 3.980507272288412*^9}, {
   3.98057195191224*^9, 3.980571968296479*^9}, {3.9810290541763783`*^9, 
   3.981029069713174*^9}, 3.9810295494789333`*^9, {3.981105359924492*^9, 
   3.9811053626325006`*^9}, {3.981108968483485*^9, 3.981108970284378*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"13aaef13-e2cc-44d1-ba3b-3a1b30d99d9c"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{"pde2", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Laplacian", "[", "\[IndentingNewLine]", 
        RowBox[{
         FractionBox[
          RowBox[{"solv", "[", 
           RowBox[{"\[Rho]", ",", "z"}], "]"}], 
          RowBox[{"r1", " ", "r2"}]], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"\[Rho]", ",", "\[CurlyPhi]", ",", "z"}], "}"}], ",", 
         "\[IndentingNewLine]", "\"\<Cylindrical\>\""}], 
        "\[IndentingNewLine]", "]"}], "-", 
       FractionBox[
        SuperscriptBox["\[Rho]", "2"], 
        RowBox[{
         SuperscriptBox["r1", "3"], 
         SuperscriptBox["r2", "3"]}]]}], "/.", "params"}], "//", 
     "Simplify"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.980507359736044*^9, 3.980507360086725*^9}, 
   3.980849606776963*^9, {3.980850325035282*^9, 3.980850333133527*^9}, 
   3.9808520130072412`*^9, 3.98085221812799*^9, 3.981029554016108*^9, 
