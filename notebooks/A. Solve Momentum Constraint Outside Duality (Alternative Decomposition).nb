Cell["Let\[CloseCurlyQuote]s create a grid to solve the PDE", "Text",
 CellChangeTimes->{{3.980851685829496*^9, 
  3.980851691741288*^9}},ExpressionUUID->"d8b1cbb8-29de-431f-a1d4-\
691133d9b066"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "number", " ", "of", " ", "points", " ", "in", " ", "each", " ", 
    "dimension"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"n", "=", "250"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"create", " ", "non"}], "-", 
     RowBox[{
     "uniform", " ", "spacing", " ", "using", " ", "a", " ", "power", " ", 
      "law", " ", "distribution"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"power", "=", "2"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"points", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"i", "/", 
          RowBox[{"(", 
           RowBox[{"n", "-", "1"}], ")"}]}], ")"}], "^", "power"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", 
         RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "create", " ", "2", "D", " ", "grid", " ", "with", " ", "same", " ", 
     "distribution", " ", "in", " ", "both", " ", "dimensions"}], " ", "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"coords", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"points", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
           RowBox[{"points", "[", 
            RowBox[{"[", 
             RowBox[{"j", "+", "1"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", 
           RowBox[{"n", "-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", 
           RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"create", " ", "quad", " ", "element", " ", "connectivity"}], " ",
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"incidents", "=", 
     RowBox[{"Flatten", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"i", "+", 
            RowBox[{"j", "*", "n"}]}], ",", 
           RowBox[{"i", "+", "1", "+", 
            RowBox[{"j", "*", "n"}]}], ",", 
           RowBox[{"i", "+", "1", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "+", "1"}], ")"}], "*", "n"}]}], ",", 
           RowBox[{"i", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "+", "1"}], ")"}], "*", "n"}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", 
           RowBox[{"n", "-", "2"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", 
       "\[IndentingNewLine]", "1"}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"create", " ", "mesh"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mesh", "=", 
     RowBox[{"ToElementMesh", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<Coordinates\>\"", "->", "coords"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<MeshElements\>\"", "->", 
        RowBox[{"{", 
         RowBox[{"QuadElement", "[", "incidents", "]"}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "visualize", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"mesh", "[", "\"\<Wireframe\>\"", "]"}], "*)"}]}]}]], "Input",
