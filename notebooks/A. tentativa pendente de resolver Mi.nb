   3.9844808239855843`*^9}},ExpressionUUID->"7505a63d-9c7d-4acc-9ae8-\
d4cbcf7b0f7e"],

Cell[TextData[{
 "The PDE\[CloseCurlyQuote]s we\[CloseCurlyQuote]re gonna solve are\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalDelta]V", "x"], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["c", "Q"], 
      SubscriptBox["z", "0"], "y"}], 
     RowBox[{"|", 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "-"], 
      SuperscriptBox["|", "3"], "|", 
      SubscriptBox[
       OverscriptBox["r", "\[RightVector]"], "+"], 
      SuperscriptBox["|", "3"]}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ffa8c999-a883-401e-b152-f1f3f5497c30"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalDelta]V", "y"], "=", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       SubscriptBox["c", "Q"], 
       SubscriptBox["z", "0"], " ", "x"}], 
      RowBox[{"|", 
       SubscriptBox[
        OverscriptBox["r", "\[RightVector]"], "-"], 
       SuperscriptBox["|", "3"], "|", 
       SubscriptBox[
        OverscriptBox["r", "\[RightVector]"], "+"], 
       SuperscriptBox["|", "3"]}]]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8a5cac53-464d-41c2-b312-184317246aa3"]
}], "Text",
 CellChangeTimes->{{3.984476241867786*^9, 3.984476248154172*^9}, {
  3.984476607607126*^9, 3.984476676155624*^9}, {3.98447710374218*^9, 
  3.984477104207315*^9}, {3.984477164315246*^9, 
  3.984477178336092*^9}},ExpressionUUID->"8711bf5c-dc11-41f6-af99-\
6474454a5205"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["r", "\[RightVector]"], "-"], TraditionalForm]],
  ExpressionUUID->"32684917-dff2-433b-afd0-95ec79bb6505"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["r", "\[RightVector]"], "+"], TraditionalForm]],
  ExpressionUUID->"ded97f2f-64e0-4fe3-99f2-37e85f7bdd64"],
 "are\n\t",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["r", "\[RightVector]"], "-"], "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", 
      RowBox[{"z", "+", 
       SubscriptBox["z", "0"]}]}], "}"}]}], TraditionalForm], "\n", 
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["r", "\[RightVector]"], "+"], "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", 
      RowBox[{"z", "-", 
       SubscriptBox["z", "0"]}]}], "}"}]}], TraditionalForm]}],ExpressionUUID->
  "aadd00a5-6689-4fa4-89f6-68e634e57e67"],
 "\n\nWe\[CloseCurlyQuote]re going to use the compactification\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"k", 
     FractionBox[
      SuperscriptBox["X", "n"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["X", "2"]}], ")"}], 
       FractionBox[
        RowBox[{"n", "+", "1"}], "2"]]]}]}], TraditionalForm]],ExpressionUUID->
  "62caca61-6cdc-4baf-93f7-df218ac928fa"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"k", 
     FractionBox[
      SuperscriptBox["Y", "n"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["Y", "2"]}], ")"}], 
       FractionBox[
        RowBox[{"n", "+", "1"}], "2"]]]}]}], TraditionalForm]], "Input",
  ExpressionUUID->"7de3c8e7-1364-4aa4-8f70-0300cc977db5"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", 
    RowBox[{"k", 
     FractionBox[
      SuperscriptBox["Z", "n"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["Z", "2"]}], ")"}], 
       FractionBox[
        RowBox[{"n", "+", "1"}], "2"]]]}]}], TraditionalForm]], "Input",
  ExpressionUUID->"f75a8e80-3b70-4a7a-9954-0b22ff76f2e1"],
 "\n\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "=", "1"}], ",", "3", ",", "5", ",", "..."}], 
   TraditionalForm]],ExpressionUUID->"39461697-c000-47e1-825a-f9d8a8863018"]
}], "Text",
 CellChangeTimes->{{3.984476158374591*^9, 3.984476210216909*^9}, {
   3.984476746273432*^9, 3.984476747907243*^9}, {3.9844806288374043`*^9, 
   3.984480693637599*^9}, {3.984481046957387*^9, 3.984481065530621*^9}, 
   3.984544834079043*^9},ExpressionUUID->"d29839ed-44b7-4fb3-ad5a-\
621dfe792e78"],

Cell[TextData[{
 "Define ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["r", "\[RightVector]"], "-"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0c27d399-40a6-482a-8b92-14cc7cbef501"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["r", "\[RightVector]"], "+"], TraditionalForm]],
  ExpressionUUID->"bdddd374-63e2-4aea-9fde-06ce685fd624"]
}], "Text",
 CellChangeTimes->{{3.984480695979426*^9, 
  3.9844807084600554`*^9}},ExpressionUUID->"430d82fa-a11e-4ae8-bbf9-\
2681e0e8fd68"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"rm", ":=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", 
     RowBox[{"z", "+", "z0"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rp", ":=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", 
     RowBox[{"z", "-", "z0"}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.980414717706162*^9, 3.98041475125744*^9}, {
  3.9805883121077127`*^9, 3.980588362546927*^9}, {3.980851899267309*^9, 
  3.980851900270152*^9}, {3.9811052596670437`*^9, 3.981105264621296*^9}, {
  3.9844761980429707`*^9, 3.984476228488309*^9}, {3.984477078943101*^9, 
