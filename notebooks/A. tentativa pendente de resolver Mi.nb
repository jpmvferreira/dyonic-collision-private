   SuperscriptBox["\"\<\!\(\*SubscriptBox[\(\|01d715\), \(Y\)]\)\>\"", "m"], 
   SuperscriptBox["\"\<\!\(\*SubscriptBox[\(\|01d715\), \(Z\)]\)\>\"", "l"], 
   RowBox[{
   "HoldForm", "[", "\"\<\!\(\*SubscriptBox[\(V\), \(y\)]\)\>\"", 
    "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.9844770329192343`*^9, 3.984477038737486*^9}, {
  3.98448075600801*^9, 3.984480772023848*^9}},
