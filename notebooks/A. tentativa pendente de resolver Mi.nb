Cell[CellGroupData[{

Cell["2. Equations", "Section",
 CellChangeTimes->{{3.980851852132537*^9, 3.980851882935902*^9}, 
   3.98102882322291*^9, {3.9844767614003153`*^9, 3.984476763075725*^9}, {
