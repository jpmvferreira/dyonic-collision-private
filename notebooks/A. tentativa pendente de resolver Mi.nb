 CellLabel->"In[9]:=",ExpressionUUID->"2abb0e34-65e5-483f-8b40-6f9fc8e3c631"],

Cell["\<\
Define the independent variables, already in compactified coordinates\
\>", "Text",
 CellChangeTimes->{{3.9844763434347143`*^9, 3.984476354980497*^9}, {
  3.9844807130286913`*^9, 
  3.984480721578062*^9}},ExpressionUUID->"6b014316-5a79-49cc-9b26-\
47740bd296aa"],

Cell[BoxData[{
 RowBox[{"Vx", ":=", 
  RowBox[{"Vxaux", "[", 
   RowBox[{"X", ",", "Y", ",", "Z"}], "]"}]}], "\n", 
 RowBox[{"Vy", ":=", 
  RowBox[{"Vyaux", "[", 
   RowBox[{"X", ",", "Y", ",", "Z"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9844763567226133`*^9, 3.984476367172456*^9}, {
  3.984480723888608*^9, 3.9844807288106813`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"175146aa-772d-4d85-9a49-59b0bed388dd"],

Cell[TextData[{
 "Compactification ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "y", ",", " ", "z"}], " ", "}"}], " ", "->", " ", 
    
    RowBox[{"{", 
     RowBox[{"X", ",", " ", "Y", ",", " ", "Z"}], " ", "}"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "32a7e6c2-580b-4f04-8302-553c67e30d60"],
 " is"
}], "Text",
 CellChangeTimes->{{3.984480832962758*^9, 3.9844808441335583`*^9}, {
  3.984480919943576*^9, 
  3.98448093842929*^9}},ExpressionUUID->"3ee7d25c-46fe-46d7-94eb-\
f00004f338b8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"compactify", ":=", 
   RowBox[{"{", "\n", "\t", 
    RowBox[{
     RowBox[{"x", "->", 
      RowBox[{"k", 
       FractionBox[
        SuperscriptBox["X", "n"], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["X", "2"]}], ")"}], 
         FractionBox[
          RowBox[{"n", "+", "1"}], "2"]]]}]}], ",", 
     RowBox[{"y", "->", 
      RowBox[{"k", 
       FractionBox[
        SuperscriptBox["Y", "n"], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["Y", "2"]}], ")"}], 
         FractionBox[
          RowBox[{"n", "+", "1"}], "2"]]]}]}], ",", 
     RowBox[{"z", "->", 
      RowBox[{"k", 
       FractionBox[
        SuperscriptBox["Z", "n"], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["Z", "2"]}], ")"}], 
         FractionBox[
          RowBox[{"n", "+", "1"}], "2"]]]}]}]}], "\n", "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9844793918454638`*^9, 3.984479489327622*^9}, {
  3.984479564601457*^9, 3.984479565538319*^9}, {3.9844804931621428`*^9, 
  3.984480495655898*^9}, {3.984481024204976*^9, 3.98448102736661*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"b98a238f-e2f2-4846-8046-496bafd4bd6a"],

Cell[TextData[{
 "The partial derivatives of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"x", ",", " ", "y", ",", " ", "z"}], " ", "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ae2b9945-d7af-4cf1-9d66-0b4f13f9ed41"],
 " as a function of compactified coordinates ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    RowBox[{"X", ",", " ", "Y", ",", " ", "Z"}], " ", "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "815c7c04-128f-4c59-9d73-6ee25f181cc0"],
 " are"
}], "Text",
 CellChangeTimes->{{3.9844805045858*^9, 3.984480518069716*^9}, {
  3.984480854709662*^9, 
  3.984480900321512*^9}},ExpressionUUID->"2b5b76fb-c606-45fc-a9e7-\
548395db5e32"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PDx", "[", "u_", "]"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["X", 
       RowBox[{"1", "-", "n"}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["X", "2"]}], ")"}], 
       FractionBox[
        RowBox[{"3", "+", "n"}], "2"]]}], 
     RowBox[{"k", " ", 
      RowBox[{"(", 
       RowBox[{"n", "+", 
        SuperscriptBox["X", "2"]}], ")"}]}]], 
    RowBox[{
     SubscriptBox["\[PartialD]", "X"], 
     RowBox[{"(", "u", ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PDy", "[", "u_", "]"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["Y", 
       RowBox[{"1", "-", "n"}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["Y", "2"]}], ")"}], 
       FractionBox[
        RowBox[{"3", "+", "n"}], "2"]]}], 
     RowBox[{"k", " ", 
      RowBox[{"(", 
       RowBox[{"n", "+", 
        SuperscriptBox["Y", "2"]}], ")"}]}]], 
    RowBox[{
     SubscriptBox["\[PartialD]", "Y"], 
     RowBox[{"(", "u", ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PDz", "[", "u_", "]"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["Z", 
       RowBox[{"1", "-", "n"}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["Z", "2"]}], ")"}], 
       FractionBox[
        RowBox[{"3", "+", "n"}], "2"]]}], 
     RowBox[{"k", " ", 
      RowBox[{"(", 
       RowBox[{"n", "+", 
        SuperscriptBox["Z", "2"]}], ")"}]}]], 
    RowBox[{
     SubscriptBox["\[PartialD]", "Z"], 
     RowBox[{"(", "u", ")"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.984480420875893*^9, 3.984480485922888*^9}, {
  3.984480590752822*^9, 3.984480596444862*^9}, {3.984481030644698*^9, 
  3.9844810352269707`*^9}, {3.984481124014505*^9, 3.984481134110018*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"ea290a41-f931-4067-bc4b-b31a449089ea"],

Cell["The compactified PDEs are", "Text",
 CellChangeTimes->{{3.9844809801746187`*^9, 3.984480992846896*^9}, {
  3.984481086338986*^9, 
  3.984481087196825*^9}},ExpressionUUID->"113510c7-2958-41fd-938e-\
8f4b1401ec1e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PDEx", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["k", "2"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"PDx", "[", 
         RowBox[{"PDx", "[", "Vx", "]"}], "]"}], "+", 
        RowBox[{"PDy", "[", 
         RowBox[{"PDy", "[", "Vx", "]"}], "]"}], "+", 
        RowBox[{"PDz", "[", 
         RowBox[{"PDz", "[", "Vx", "]"}], "]"}]}], ")"}]}], "//", 
     "FullSimplify"}], ")"}], "-", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["k", "2"], 
       FractionBox[
        RowBox[{"cQ", " ", "z0", " ", "y"}], 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"rm", ".", "rm"}], ")"}], 
          RowBox[{"3", "/", "2"}]], 
         SuperscriptBox[
