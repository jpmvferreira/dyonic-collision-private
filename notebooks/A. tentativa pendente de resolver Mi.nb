c260e2b8d4a5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
  "Format", "[", "\[IndentingNewLine]", "z0", "\[IndentingNewLine]", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(z\), \(0\)]\)\>\""}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
  "Format", "[", "\[IndentingNewLine]", "cQ", "\[IndentingNewLine]", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(c\), \(Q\)]\)\>\""}]}], "Input",
 CellChangeTimes->{{3.9810289136338177`*^9, 3.98102895547998*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"c37afe61-9d71-425d-b44d-0e14c33a15cd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Format", "[", "\[IndentingNewLine]", 
   RowBox[{"Vxaux", "[", 
    RowBox[{"X", ",", "Y", ",", "Z"}], "]"}], "\[IndentingNewLine]", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(V\), \(x\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "\[IndentingNewLine]", 
   RowBox[{"D", "[", "\n", "\t", 
    RowBox[{
     RowBox[{"Vxaux", "[", 
      RowBox[{"X", ",", "Y", ",", "Z"}], "]"}], ",", " ", "\n", "\t", 
     RowBox[{"{", 
      RowBox[{"X", ",", " ", "n_"}], "}"}], ",", "\n", "\t", 
     RowBox[{"{", 
      RowBox[{"Y", ",", " ", "m_"}], "}"}], ",", "\n", "\t", 
     RowBox[{"{", 
      RowBox[{"Z", ",", " ", "l_"}], "}"}]}], "\[IndentingNewLine]", "]"}], 
   "\[IndentingNewLine]", "]"}], " ", ":=", " ", 
  RowBox[{
   SuperscriptBox["\"\<\!\(\*SubscriptBox[\(\|01d715\), \(X\)]\)\>\"", "n"], 
   SuperscriptBox["\"\<\!\(\*SubscriptBox[\(\|01d715\), \(Y\)]\)\>\"", "m"], 
   SuperscriptBox["\"\<\!\(\*SubscriptBox[\(\|01d715\), \(Z\)]\)\>\"", "l"], 
   RowBox[{
   "HoldForm", "[", "\"\<\!\(\*SubscriptBox[\(V\), \(x\)]\)\>\"", 
    "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.984476406302842*^9, 3.9844764104231863`*^9}, {
  3.984476477319468*^9, 3.984476551324996*^9}, {3.984480735208097*^9, 
  3.984480753965571*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"1726c7d4-db20-4223-9849-5fb8fce3a279"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Format", "[", "\[IndentingNewLine]", 
   RowBox[{"Vyaux", "[", 
    RowBox[{"X", ",", "Y", ",", "Z"}], "]"}], "\[IndentingNewLine]", "]"}], 
  ":=", "\"\<\!\(\*SubscriptBox[\(V\), \(y\)]\)\>\""}], "\n", 
 RowBox[{
  RowBox[{"Format", "[", "\[IndentingNewLine]", 
   RowBox[{"D", "[", "\n", "\t", 
    RowBox[{
     RowBox[{"Vyaux", "[", 
      RowBox[{"X", ",", "Y", ",", "Z"}], "]"}], ",", " ", "\n", "\t", 
     RowBox[{"{", 
      RowBox[{"X", ",", " ", "n_"}], "}"}], ",", "\n", "\t", 
     RowBox[{"{", 
      RowBox[{"Y", ",", " ", "m_"}], "}"}], ",", "\n", "\t", 
     RowBox[{"{", 
