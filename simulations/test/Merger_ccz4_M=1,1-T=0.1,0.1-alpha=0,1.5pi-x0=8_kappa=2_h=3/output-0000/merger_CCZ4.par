#------------------------------------------------------------------------------
# Active thorns
#------------------------------------------------------------------------------

# Carpet and other basic infrastructure
ActiveThorns = "
  ADMBase
  ADMCoupling
  ADMMacros
  AEILocalInterp
  AHFinderDirect
  Boundary
  Carpet
  CarpetInterp
  CarpetLib
  CarpetMask
  CarpetReduce
  CarpetRegrid2
  CarpetSlab
  CarpetTracker
  CartGrid3D
  CoordBase
  CoordGauge
  Dissipation
  GenericFD
  InitBase
  LocalInterp
  LoopControl
  MoL
  Multipole
  NaNChecker
  NewRad
  PunctureTracker
  ReflectionSymmetry
  Slab
  SpaceMask
  SphericalSurface
  StaticConformal
  SymBase
  Time
  TmunuBase
"

# libraries
ActiveThorns = "
  Fortran
  GSL
  HDF5
"

# evolution thorns
ActiveThorns = "
  ML_CCZ4
  ML_CCZ4_Helper
"

# matter fields
ActiveThorns = "
  EMGBase
  EMGEvolve
  TwoChargedPunctures
"

# analysis thorns
ActiveThorns = "
  NPScalars
  NPScalars_EMG
  QuasiLocalMeasures
"

# statistics and utilities
ActiveThorns = "
  SystemStatistics
  TerminationTrigger
  TimerReport
"

# I/O
ActiveThorns = "
  CarpetIOASCII
  CarpetIOBasic
  CarpetIOHDF5
  CarpetIOScalar
  IOUtil
"


#------------------------------------------------------------------------------
# Grid setup
#------------------------------------------------------------------------------

CartGrid3D::type                     = "coordbase"
Carpet::domain_from_coordbase        = yes
CoordBase::domainsize                = "minmax"

# make sure all (xmax - xmin)/dx are integers!
CoordBase::xmin                      = -252.00
CoordBase::ymin                      = -252.00
CoordBase::zmin                      = -252.00
CoordBase::xmax                      = +252.00
CoordBase::ymax                      = +252.00
CoordBase::zmax                      = +252.00
CoordBase::dx                        =    3.
CoordBase::dy                        =    3.
CoordBase::dz                        =    3.

driver::ghost_size                   = 3

CoordBase::boundary_size_x_lower     = 3
CoordBase::boundary_size_y_lower     = 3
CoordBase::boundary_size_z_lower     = 3
CoordBase::boundary_size_x_upper     = 3
CoordBase::boundary_size_y_upper     = 3
CoordBase::boundary_size_z_upper     = 3

CoordBase::boundary_shiftout_x_lower = 0
CoordBase::boundary_shiftout_y_lower = 0
CoordBase::boundary_shiftout_z_lower = 0

CarpetRegrid2::symmetry_rotating180  = no

ReflectionSymmetry::reflection_x     = no
ReflectionSymmetry::reflection_y     = no
ReflectionSymmetry::reflection_z     = no
ReflectionSymmetry::avoid_origin_x   = no
ReflectionSymmetry::avoid_origin_y   = no
ReflectionSymmetry::avoid_origin_z   = no


#------------------------------------------------------------------------------
# Mesh refinement
#------------------------------------------------------------------------------

Carpet::max_refinement_levels          = 8

CarpetRegrid2::num_centres             = 2

CarpetRegrid2::num_levels_1            =  8
CarpetRegrid2::position_x_1            =  8
CarpetRegrid2::radius_1[ 1]            =  64.0
CarpetRegrid2::radius_1[ 2]            =  16.0
CarpetRegrid2::radius_1[ 3]            =   8.0
CarpetRegrid2::radius_1[ 4]            =   4.0
CarpetRegrid2::radius_1[ 5]            =   2.0
CarpetRegrid2::radius_1[ 6]            =   1.0
CarpetRegrid2::radius_1[ 7]            =   0.5
CarpetRegrid2::movement_threshold_1    =   0.16

CarpetRegrid2::num_levels_2            =  8
CarpetRegrid2::position_x_2            =  -8
CarpetRegrid2::radius_2[ 1]            =  64.0
CarpetRegrid2::radius_2[ 2]            =  16.0
CarpetRegrid2::radius_2[ 3]            =   8.0
CarpetRegrid2::radius_2[ 4]            =   4.0
CarpetRegrid2::radius_2[ 5]            =   2.0
CarpetRegrid2::radius_2[ 6]            =   1.0
CarpetRegrid2::radius_2[ 7]            =   0.5
CarpetRegrid2::movement_threshold_2    =   0.16

Carpet::use_buffer_zones               = yes
Carpet::prolongation_order_space       = 5
Carpet::prolongation_order_time        = 2

CarpetRegrid2::freeze_unaligned_levels = yes
CarpetRegrid2::regrid_every            = 64

CarpetRegrid2::verbose                 = yes

Carpet::grid_structure_filename        = "carpet-grid-structure"
Carpet::grid_coordinates_filename      = "carpet-grid-coordinates"

Carpet::time_refinement_factors        = "[1, 1, 2, 4, 8, 16, 32, 64, 128, 256, 512]"

Time::dtfac                            = 0.25


#------------------------------------------------------------------------------
# Initial Data
#------------------------------------------------------------------------------

ADMBase::lapse_timelevels  = 3
ADMBase::shift_timelevels  = 3
ADMBase::metric_timelevels = 3

InitBase::initial_data_setup_method = "init_some_levels"
Carpet::init_fill_timelevels        = yes
Carpet::init_3_timelevels           = no

ADMBase::initial_data    = "twochargedpunctures"
ADMBase::initial_lapse   = "psi^n"
ADMBase::initial_shift   = "zero"
ADMBase::initial_dtlapse = "zero"
ADMBase::initial_dtshift = "zero"

TwoChargedPunctures::target_M_plus       = 1.0
TwoChargedPunctures::target_M_minus      = 1.0

TwoChargedPunctures::par_m_plus          = 1.0
TwoChargedPunctures::par_m_minus         = 1.0

TwoChargedPunctures::par_q_plus          = 0.1
TwoChargedPunctures::par_q_minus         = 0.1

TwoChargedPunctures::alpha_duality_plus  = 0.
TwoChargedPunctures::alpha_duality_minus = 4.71238898

TwoChargedPunctures::par_b               = 8.001
TwoChargedPunctures::center_offset[0]    = 0.0

TwoChargedPunctures::par_P_plus[0]       = -0.000420160798841856
TwoChargedPunctures::par_P_plus[1]       = 0.140798664385624
TwoChargedPunctures::par_P_plus[2]       = 0

TwoChargedPunctures::par_P_minus[0]      = 0.000420160798841856
TwoChargedPunctures::par_P_minus[1]      = -0.140798664385624
TwoChargedPunctures::par_P_minus[2]      = 0

TwoChargedPunctures::par_S_plus[0]       = 0.
TwoChargedPunctures::par_S_plus[1]       = 0.
TwoChargedPunctures::par_S_plus[2]       = 0.

TwoChargedPunctures::par_S_minus[0]      = 0.
TwoChargedPunctures::par_S_minus[1]      = 0.
TwoChargedPunctures::par_S_minus[2]      = 0.

TwoChargedPunctures::give_bare_mass      = yes

TwoChargedPunctures::TCP_epsilon         = 1.0e-6
TwoChargedPunctures::TCP_Tiny            = 1.e-10

TwoChargedPunctures::npoints_A           = 64
TwoChargedPunctures::npoints_B           = 64
TwoChargedPunctures::npoints_phi         = 32
TwoChargedPunctures::grid_setup_method   = "evaluation"

TwoChargedPunctures::keep_u_around       = yes
TwoChargedPunctures::verbose             = yes

TwoChargedPunctures::Newton_tol          = 5e-7


#------------------------------------------------------------------------------
# Evolution
#------------------------------------------------------------------------------

TmunuBase::stress_energy_storage = yes
TmunuBase::stress_energy_at_RHS  = yes
TmunuBase::timelevels            = 1
TmunuBase::prolongation_type     = "none"

EMGBase::evolution_method              = "EMGEvolve"
EMGEvolve::calculate_constraints       = yes
EMGEvolve::calculate_constraints_every = 128
EMGEvolve::excise_horizon              = yes

EMGEvolve::kappa = 2

ADMBase::evolution_method         = "ML_CCZ4"
ADMBase::lapse_evolution_method   = "ML_CCZ4"
ADMBase::shift_evolution_method   = "ML_CCZ4"
ADMBase::dtlapse_evolution_method = "ML_CCZ4"
ADMBase::dtshift_evolution_method = "ML_CCZ4"

ML_CCZ4::harmonicN       = 1      # 1+log
ML_CCZ4::harmonicF       = 2.0    # 1+log
ML_CCZ4::ShiftGammaCoeff = 0.75
ML_CCZ4::BetaDriver      = 1.0
ML_CCZ4::advectLapse     = 1
ML_CCZ4::advectShift     = 1
ML_CCZ4::dampk1          = 0.04
ML_CCZ4::dampk2          = 0.0

ML_CCZ4::MinimumLapse               = 1.0e-8
ML_CCZ4::conformalMethod            = 1 # 1 for W, 0 for phi
ML_CCZ4::rhs_boundary_condition     = "NewRad"   # was "static"
ML_CCZ4::initial_boundary_condition = "extrapolate-gammas"
Boundary::radpower                  = 2

ML_CCZ4::ML_log_confac_bound = "none"
ML_CCZ4::ML_metric_bound     = "none"
ML_CCZ4::ML_Gamma_bound      = "none"
ML_CCZ4::ML_trace_curv_bound = "none"
ML_CCZ4::ML_curv_bound       = "none"
ML_CCZ4::ML_lapse_bound      = "none"
ML_CCZ4::ML_dtlapse_bound    = "none"
ML_CCZ4::ML_shift_bound      = "none"
ML_CCZ4::ML_dtshift_bound    = "none"
#ML_CCZ4::apply_dissipation   = "always"
#ML_CCZ4::EpsDiss             = 0.1


#------------------------------------------------------------------------------
# Dissipation
#------------------------------------------------------------------------------

Dissipation::epsdis_for_level[0] = 8.73114913702011e-12
Dissipation::epsdis_for_level[1] = 2.7939677238464354e-10
Dissipation::epsdis_for_level[2] = 8.940696716308593e-09
Dissipation::epsdis_for_level[3] = 2.86102294921875e-07
Dissipation::epsdis_for_level[4] = 9.1552734375e-06
Dissipation::epsdis_for_level[5] = 0.00029296875
Dissipation::epsdis_for_level[6] = 0.009375
Dissipation::epsdis_for_level[7] = 0.3
Dissipation::order = 5
Dissipation::vars  = "
  ML_CCZ4::ML_log_confac
  ML_CCZ4::ML_metric
  ML_CCZ4::ML_trace_curv
  ML_CCZ4::ML_curv
  ML_CCZ4::ML_Gamma
  ML_CCZ4::ML_lapse
  ML_CCZ4::ML_shift
  ML_CCZ4::ML_dtlapse
  ML_CCZ4::ML_dtshift
  EMGBase::Ei
  EMGBase::Bi
  EMGBase::Omega
  EMGBase::Zeta
"


#------------------------------------------------------------------------------
# Integration method
#------------------------------------------------------------------------------

MoL::ODE_Method                 = "RK4"
MoL::MoL_Intermediate_Steps     = 4
MoL::MoL_Num_Scratch_Levels     = 1

Carpet::num_integrator_substeps = 4


#------------------------------------------------------------------------------
# Spherical surfaces
#------------------------------------------------------------------------------

SphericalSurface::nsurfaces = 6
SphericalSurface::maxntheta = 66
SphericalSurface::maxnphi   = 124
SphericalSurface::verbose   = no

