#------------------------------------------------------------------------------
# Check for NaNs
#------------------------------------------------------------------------------

Carpet::poison_new_timelevels = no
CarpetLib::poison_new_memory  = no
#Carpet::poison_value          = 378423.
Carpet::check_for_poison      = no

